From d816824af5c3b8467c3a9570f76d7a6c793744f6 Mon Sep 17 00:00:00 2001
From: Alessio Igor Bogani <alessio.bogani@elettra.eu>
Date: Mon, 9 Mar 2026 09:50:39 +0100
Subject: [PATCH 2/2] ptp: ptp_qoriq: fix NULL pointer dereference on probe
 failure
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

When ptp_qoriq_auto_config() fails (e.g. reference clock < 100MHz),
ptp_qoriq_init() returns early before initializing the read/write
function pointers and the regs structure. On the error path,
free_irq() may trigger the shared IRQ handler ptp_qoriq_isr(), which
calls ptp_qoriq->read() — a NULL pointer — causing a kernel oops.

Fix two issues:

1. Move the read/write function pointer and regs initialization in
   ptp_qoriq_init() to before the DT property parsing and auto_config
   call. This ensures the ISR can safely access hardware registers
   even if the configuration step fails.

2. Reorder the no_clock error path in ptp_qoriq_probe() to call
   free_irq() before iounmap(), preventing the ISR from accessing
   unmapped register space during interrupt synchronization.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 drivers/ptp/ptp_qoriq.c | 48 ++++++++++++++++++++++-------------------
 1 file changed, 26 insertions(+), 22 deletions(-)

diff --git a/drivers/ptp/ptp_qoriq.c b/drivers/ptp/ptp_qoriq.c
index a52859d024f0..7d22c6b41a61 100644
--- a/drivers/ptp/ptp_qoriq.c
+++ b/drivers/ptp/ptp_qoriq.c
@@ -473,20 +473,42 @@ int ptp_qoriq_init(struct ptp_qoriq *ptp_qoriq, void __iomem *base,
 	struct timespec64 now;
 	unsigned long flags;
 	u32 tmr_ctrl;
 
 	if (!node)
 		return -ENODEV;
 
 	ptp_qoriq->base = base;
 	ptp_qoriq->caps = *caps;
 
+	if (of_property_read_bool(node, "little-endian")) {
+		ptp_qoriq->read = qoriq_read_le;
+		ptp_qoriq->write = qoriq_write_le;
+	} else {
+		ptp_qoriq->read = qoriq_read_be;
+		ptp_qoriq->write = qoriq_write_be;
+	}
+
+	/* The eTSEC uses differnt memory map with DPAA/ENETC */
+	if (of_device_is_compatible(node, "fsl,etsec-ptp")) {
+		ptp_qoriq->etsec = true;
+		ptp_qoriq->regs.ctrl_regs = base + ETSEC_CTRL_REGS_OFFSET;
+		ptp_qoriq->regs.alarm_regs = base + ETSEC_ALARM_REGS_OFFSET;
+		ptp_qoriq->regs.fiper_regs = base + ETSEC_FIPER_REGS_OFFSET;
+		ptp_qoriq->regs.etts_regs = base + ETSEC_ETTS_REGS_OFFSET;
+	} else {
+		ptp_qoriq->regs.ctrl_regs = base + CTRL_REGS_OFFSET;
+		ptp_qoriq->regs.alarm_regs = base + ALARM_REGS_OFFSET;
+		ptp_qoriq->regs.fiper_regs = base + FIPER_REGS_OFFSET;
+		ptp_qoriq->regs.etts_regs = base + ETTS_REGS_OFFSET;
+	}
+
 	if (of_property_read_u32(node, "fsl,cksel", &ptp_qoriq->cksel))
 		ptp_qoriq->cksel = DEFAULT_CKSEL;
 
 	if (of_property_read_bool(node, "fsl,extts-fifo"))
 		ptp_qoriq->extts_fifo_support = true;
 	else
 		ptp_qoriq->extts_fifo_support = false;
 
 	if (of_device_is_compatible(node, "fsl,dpaa2-ptp") ||
 	    of_device_is_compatible(node, "fsl,enetc-ptp"))
@@ -506,42 +528,20 @@ int ptp_qoriq_init(struct ptp_qoriq *ptp_qoriq, void __iomem *base,
 				 "fsl,max-adj", &ptp_qoriq->caps.max_adj) ||
 	    (ptp_qoriq->fiper3_support &&
 	     of_property_read_u32(node, "fsl,tmr-fiper3",
 				  &ptp_qoriq->tmr_fiper3))) {
 		pr_warn("device tree node missing required elements, try automatic configuration\n");
 
 		if (ptp_qoriq_auto_config(ptp_qoriq, node))
 			return -ENODEV;
 	}
 
-	if (of_property_read_bool(node, "little-endian")) {
-		ptp_qoriq->read = qoriq_read_le;
-		ptp_qoriq->write = qoriq_write_le;
-	} else {
-		ptp_qoriq->read = qoriq_read_be;
-		ptp_qoriq->write = qoriq_write_be;
-	}
-
-	/* The eTSEC uses differnt memory map with DPAA/ENETC */
-	if (of_device_is_compatible(node, "fsl,etsec-ptp")) {
-		ptp_qoriq->etsec = true;
-		ptp_qoriq->regs.ctrl_regs = base + ETSEC_CTRL_REGS_OFFSET;
-		ptp_qoriq->regs.alarm_regs = base + ETSEC_ALARM_REGS_OFFSET;
-		ptp_qoriq->regs.fiper_regs = base + ETSEC_FIPER_REGS_OFFSET;
-		ptp_qoriq->regs.etts_regs = base + ETSEC_ETTS_REGS_OFFSET;
-	} else {
-		ptp_qoriq->regs.ctrl_regs = base + CTRL_REGS_OFFSET;
-		ptp_qoriq->regs.alarm_regs = base + ALARM_REGS_OFFSET;
-		ptp_qoriq->regs.fiper_regs = base + FIPER_REGS_OFFSET;
-		ptp_qoriq->regs.etts_regs = base + ETTS_REGS_OFFSET;
-	}
-
 	spin_lock_init(&ptp_qoriq->lock);
 
 	ktime_get_real_ts64(&now);
 	ptp_qoriq_settime(&ptp_qoriq->caps, &now);
 
 	tmr_ctrl =
 	  (ptp_qoriq->tclk_period & TCLK_PERIOD_MASK) << TCLK_PERIOD_SHIFT |
 	  (ptp_qoriq->cksel & CKSEL_MASK) << CKSEL_SHIFT;
 
 	spin_lock_irqsave(&ptp_qoriq->lock, flags);
@@ -630,21 +630,25 @@ static int ptp_qoriq_probe(struct platform_device *dev)
 	}
 
 	err = ptp_qoriq_init(ptp_qoriq, base, &ptp_qoriq_caps);
 	if (err)
 		goto no_clock;
 
 	platform_set_drvdata(dev, ptp_qoriq);
 	return 0;
 
 no_clock:
+	free_irq(ptp_qoriq->irq, ptp_qoriq);
 	iounmap(base);
+	release_resource(ptp_qoriq->rsrc);
+	kfree(ptp_qoriq);
+	return err;
 no_ioremap:
 	release_resource(ptp_qoriq->rsrc);
 no_resource:
 	free_irq(ptp_qoriq->irq, ptp_qoriq);
 no_node:
 	kfree(ptp_qoriq);
 no_memory:
 	return err;
 }
 
