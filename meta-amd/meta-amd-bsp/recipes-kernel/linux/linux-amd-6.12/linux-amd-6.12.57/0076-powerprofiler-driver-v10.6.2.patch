+// IsZen4AndAbove: Returns whether the processor is Zen4 and above or not
+bool IsZen4AndAbove(void)
+{
+    bool isZen4AndAbove = false;
+    uint32 family = 0, model = 0;
+    GetCpuModelFamily(&family, &model);
+    isZen4AndAbove = (0x19 == family &&
+                        ((model >= 0x10 && model <= 0x1f) || // RS
+                         (model >= 0xa0 && model <= 0xaf) || // RSDN
+                         (model >= 0x60 && model <= 0x6f) || // RPL
+                         (model >= 0x70 && model <= 0x7f) || // PHX & PHX2
+                         (model >= 0x80 && model <= 0x8f) || // MI300C
+                         (model >= 0x90 && model <= 0x9f)) // MI300A
+                      ) ||
+                      (family > 0x19); // Zen5
+
+    DRVPRINT("isZen4AndAbove(%d) family(0x%x) model(0x%x)", isZen4AndAbove, family, model);
+
+    return isZen4AndAbove;
