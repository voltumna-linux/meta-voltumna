+// THE SOFTWARE.
+//
+/// \author AMD Developer Tools Team
+/// \file PmcIohcProcessConfig.c
+///
+//==================================================================================
+
+// Project Includes:
+#include <PmcProcessConfig.h>
+#include <PmcIohcProcessConfig.h>
+#include <PmcUtils.h>
+#include <PmcTimerConfig.h>
+#include <PwrOsPrimitives.h>
+#include <PmcDataBuffer.h>
+#include <PmcDataBufferOps.h>
+#include <PwrDriverUtils.h>
+
+#if defined(_WIN32)
+    #include <errno.h>
+#endif
+
+#if defined(__linux__)
+    #include <linux/cpumask.h>
+#endif
+
+#if defined (_WIN32)
+    #include <intrin.h>
+    #define POPCNT(x)   __popcnt(x)
+#elif defined (__linux__)
+    #define POPCNT(x)   __builtin_popcount(x)
+#endif
+
+int LoadSmnIohcConfig(ClientContext* pClientCtx, int smnTypeIdx, PmcConfigGroup* pPmcConfigGroup, uint32_t socketId, uint16_t maxPmcCnt, bool reset)
+{
+    uint16_t pmcConfigCnt;
+    uint32_t val = 0;
+    uint32_t pmcIdx = 0;
+    uint32_t unitIdx = 0;
+    uint32_t configArrayIdx = 0;
+    uint64_t controlValue = 0;
+    int maxNbioConfigs = 0;
+    int nbioIdx = 0;
+    int retVal = 0;
+
+    CountModeProfileSmnConfig *pSmnConfig = NULL;
+    PmcConfig* pPmcConfigArray = NULL;
+    SmnNbioFieldsConfig* pNbioConfig = NULL;
+    PTARGET_SYSTEM_INFO pTargetSystemInfo = NULL;
+
+    GetTargetSystemInfo(&pTargetSystemInfo, false);
+
+    // Validate input parameters
+    if (pClientCtx == NULL || pTargetSystemInfo == NULL || pPmcConfigGroup == NULL || 
+        pPmcConfigGroup->m_pPmcConfigArray == NULL || pClientCtx->m_pSmnConfig == NULL)
+    {
+        DRVPRINTERROR("Error: One or more required pointers are NULL");
+        retVal = -1;
+    }
+    // Validate smnTypeIdx bounds
+    if (smnTypeIdx < 0 || smnTypeIdx >= (PMC_PMU_MAX - PMC_PMU_MSR_MAX))
+    {
+        DRVPRINTERROR("Error: Invalid smnTypeIdx %d", smnTypeIdx);
+        retVal = -1;
+    }
+
+    if (!retVal)
+    {
+        pSmnConfig = &pClientCtx->m_pSmnConfig[smnTypeIdx];
+        if (pSmnConfig == NULL)
+        {
+            retVal = -1;
+            DRVPRINTERROR("Error: NULL ptr pSmnConfig");
+        }
+    }
+
+    if (!retVal)
+    {
+        maxNbioConfigs = sizeof(pSmnConfig->m_nbioFieldsConfig) / sizeof(pSmnConfig->m_nbioFieldsConfig[0]);
+        pPmcConfigArray = pPmcConfigGroup->m_pPmcConfigArray;
+        if (pPmcConfigArray == NULL)
+        {
+            DRVPRINTERROR("Error: pPmcConfigArray ptr is NULL");
+            retVal = -1;
+        }
+    }
+
+    if (!retVal)
+    {
+        pmcConfigCnt = pPmcConfigGroup->m_pmcConfigCnt;
+
+        for (pmcIdx = 0; pmcIdx < maxPmcCnt && pmcConfigCnt > 0; pmcIdx++)
+        {
+            // Validate nbioIdx bounds before accessing array
+            if (nbioIdx >= maxNbioConfigs)
+            {
+                DRVPRINTERROR("Error: Invalid NBIO index %d exceeds maxNbioConfigs %d", nbioIdx, maxNbioConfigs);
+                retVal = -1;
+                break;
+            }
+
+            pNbioConfig = &pSmnConfig->m_nbioFieldsConfig[nbioIdx];
+            if (pNbioConfig == NULL)
+            {
+                DRVPRINTERROR("Error: pNbioConfig ptr is NULL");
+                continue;
+            }
+
+            if (pNbioConfig->m_eventsPerPmcCnt == 0)
+            {
+                DRVPRINTERROR("Error: eventsPerPmcCnt is 0, would cause division by zero");
+                retVal = -1;
+                break;
+            }
+
+            if ((pmcIdx % pNbioConfig->m_eventsPerPmcCnt) == 0)
+            {
+                controlValue = 0;
+            }
+
+            configArrayIdx = pmcIdx;
+            // Additional bounds check for array access
+            if (configArrayIdx >= pPmcConfigGroup->m_pmcConfigCnt || configArrayIdx >= maxPmcCnt)
+            {
+                DRVPRINTERROR("Error: Config array index %d exceeds bounds (count: %d, max: %d)", 
+                            configArrayIdx, pPmcConfigGroup->m_pmcConfigCnt, maxPmcCnt);
+                retVal = -1;
+                break;
+            }
+            
+            if (pPmcConfigArray[configArrayIdx].m_controlValue != NBIO_DUMMY_EVENT)
+            {
+                controlValue |= (pPmcConfigArray[configArrayIdx].m_controlValue << ((pmcIdx % pNbioConfig->m_eventsPerPmcCnt) * 8));
+            }
+
+            if (((pmcIdx + 1) % pNbioConfig->m_eventsPerPmcCnt == 0))
+            {
+                DRVPRINT("NBIO[%d]: nbioCnt=%u, eventsPerPmc=%u, perfCntBase=0x%x, socketId=%u",
+                        nbioIdx, pNbioConfig->m_nbioCnt, pNbioConfig->m_eventsPerPmcCnt, 
+                        pNbioConfig->m_nbioPerfCntBase, socketId);
+
+                for (unitIdx = 0; unitIdx < pNbioConfig->m_nbioCnt; unitIdx++)
+                {
+                    uint32_t perfCntBase = pNbioConfig->m_nbioPerfCntBase + (unitIdx * pNbioConfig->m_nbioPerfCntStride);
+                    uint32_t ctlRegBase = pNbioConfig->m_nbioCtlReg + (unitIdx * pNbioConfig->m_nbioCtlRegStride) + pNbioConfig->m_nbioCtrlRegOffset;
+
+                    // Reset/Enable this NBIO unit's performance counters
+                    ACCESS_SMN smnAccess = {0};
+                    smnAccess.m_isReadAccess = true;
+                    smnAccess.m_socket = socketId;  // Assuming socket 0
+                    smnAccess.m_address = perfCntBase; // NBIO_PERF_CNT_CTRL_OFFSET
+                    smnAccess.m_isBus = false;
+                    smnAccess.m_isMultiDomain = false;
+                    smnAccess.m_domainId = 0;
+
+                    if (!AccessSMN(pTargetSystemInfo, &smnAccess))
+                    {
+                        DRVPRINTERROR("Error: Failed to read NBIO PMC at 0x%x", smnAccess.m_address);
+                        retVal = -1;
+                        continue;
+                    }
+
+                    val = smnAccess.m_data;
+                    val &= 0xFFFFFFF8;
+                    val |= 0x5;  // From PPR (IOHC::NB_PERF_CNT_CTRL): reset & enable
+                    
+                    smnAccess.m_isReadAccess = false;
+
+                    // Write to IOHC PMC control register via AccessSMN
+                    if (controlValue)
+                    {
+                        smnAccess.m_address = ctlRegBase;
+                        smnAccess.m_data = (uint32_t)controlValue;
+                        if (!AccessSMN(pTargetSystemInfo, &smnAccess))
+                        {
+                            DRVPRINTERROR("Error: Failed to write IOHC PMC control register at 0x%x", smnAccess.m_address);
+                            retVal = -1;
+                            continue;
+                        }
+                    }
+
+                    smnAccess.m_address = perfCntBase; // NBIO_PERF_CNT_CTRL_OFFSET
+                    smnAccess.m_data = val;  // Reset value
+                    if (!AccessSMN(pTargetSystemInfo, &smnAccess))
+                    {
+                        DRVPRINTERROR("Error: Failed to load NBIO PMC at 0x%x", smnAccess.m_address);
+                        retVal = -1;
+                        continue;
+                    }
+                }
+            }
+
+            -- pmcConfigCnt;
+            nbioIdx = (int)(pmcIdx / pNbioConfig->m_eventsPerPmcCnt);
+            if (nbioIdx > maxNbioConfigs)
+            {
+                DRVPRINTERROR("Error: Invalid NBIO index %d for pmcIdx %d", nbioIdx, pmcIdx);
+                retVal = -1;
+                continue;
+            }
+        }
+    }
+    
+    return retVal;
+}
+
+void ResetNbioConfigGroup(ClientContext* pClientCtx, uint32_t socketId, int smnTypeIdx)
+{
+    uint8_t unitIdx = 0;
+    uint32_t val = 0;
+    int nbioIdx = 0;
+    CountModeProfileSmnConfig *pSmnConfig = NULL;
+    PTARGET_SYSTEM_INFO pTargetSystemInfo = NULL;
+
+    // Get target system info for SMN access
+    GetTargetSystemInfo(&pTargetSystemInfo, false);
+
+    // Validate input parameters
+    if (pClientCtx == NULL || pTargetSystemInfo == NULL || pClientCtx->m_pSmnConfig == NULL ||
+        smnTypeIdx < 0 || smnTypeIdx >= (PMC_PMU_MAX - PMC_PMU_MSR_MAX))
+    {
+        DRVPRINTERROR("Error: Invalid parameters or pointers are NULL");
+        return;
+    }
+
+    pSmnConfig = &pClientCtx->m_pSmnConfig[smnTypeIdx];
+    if (pSmnConfig == NULL)
+    {
+        DRVPRINTERROR("Error: NULL ptr pSmnConfig");
+        return;
+    }
+
+    // loop twice because IOHC has 2 types of counters: normal and SION
+    for (nbioIdx = 0; nbioIdx < 2; nbioIdx++)
+    {
+        SmnNbioFieldsConfig* pNbioConfig = NULL;
+        pNbioConfig = &pSmnConfig->m_nbioFieldsConfig[nbioIdx];
+        if (pNbioConfig == NULL)
+        {
+            DRVPRINTERROR("Error: pNbioConfig ptr is NULL");
+            return;
+        }
+
+        for (unitIdx = 0; unitIdx < pNbioConfig->m_nbioCnt; unitIdx++)
+        {
+            uint32_t perfCntBase = pNbioConfig->m_nbioPerfCntBase + (unitIdx * pNbioConfig->m_nbioPerfCntStride);
+
+            // Reset this NBIO unit's performance counters
+            ACCESS_SMN smnAccess = {0};
+            smnAccess.m_isReadAccess = true;
+            smnAccess.m_socket = socketId;  // Assuming socket 0
+            smnAccess.m_address = perfCntBase; // NBIO_PERF_CNT_CTRL_OFFSET
+            smnAccess.m_isBus = false;
+            smnAccess.m_isMultiDomain = false;
+            smnAccess.m_domainId = 0;
+
+            if (!AccessSMN(pTargetSystemInfo, &smnAccess))
+            {
+                DRVPRINTERROR("Error: Failed to read NBIO PMC at 0x%x", smnAccess.m_address);
+                continue;
+            }
+
+            val = smnAccess.m_data;
+            val &= 0xFFFFFFF8;
+            val |= 0x5;  // From PPR (IOHC::NB_PERF_CNT_CTRL): reset & enable
+            smnAccess.m_data = val;  // Reset value
+            smnAccess.m_isReadAccess = false;
+
+            if (!AccessSMN(pTargetSystemInfo, &smnAccess))
+            {
+                DRVPRINTERROR("Error: Failed to reset NBIO PMC at 0x%x", smnAccess.m_address);
+                continue;
+            }
+        }
+    }
+}
+
+int ReadIohcPmcConfigGroup(ClientContext* pClientCtx, PmcConfigGroup* pPmcConfigGroup, int smnTypeIdx, uint32_t socketId, uint16_t maxPmcCnt)
+{
+    uint32_t valHi = 0;
+    uint32_t val = 0;
+    uint32_t perfCntBase = 0;
+    uint32_t ctrRegLoBase = 0;
+    uint32_t ctrRegHiBase = 0;
+    uint32_t unitIdx = 0;
+    uint32_t msrIdx = 0;
+    uint16_t pmcConfigCnt = 0;
+    uint8_t nbioCnt = 0;
+    uint8_t ctrIdx = 0;
+    int eventsPerPmc = 0;
+    int maxNbioConfigs = 0;
+    int nbioIdx = 0;
+    int pmcIdx = 0;
+    int retVal = 0;
+    CountModeProfileSmnConfig *pSmnConfig = NULL;
+    SmnNbioFieldsConfig* pNbioConfig = NULL;
+    PmcConfig* pPmcConfigArray = NULL;
+    ACCESS_SMN smnAccess = {0};
+    PTARGET_SYSTEM_INFO pTargetSystemInfo = NULL;
+
+    // Get target system info for SMN access
+    GetTargetSystemInfo(&pTargetSystemInfo, false);
+
+    // Validate input parameters
+    if (pClientCtx == NULL || pTargetSystemInfo == NULL || pPmcConfigGroup == NULL || 
+        pPmcConfigGroup->m_pPmcConfigArray == NULL || pClientCtx->m_pSmnConfig == NULL ||
+        smnTypeIdx < 0 || smnTypeIdx >= (PMC_PMU_MAX - PMC_PMU_MSR_MAX))
+    {
+        retVal = -1;
+        DRVPRINTERROR("Error: Invalid parameters or pointers are NULL");
+    }
+
+    if (!retVal)
+    {
+        pPmcConfigArray = pPmcConfigGroup->m_pPmcConfigArray;
+        if (pPmcConfigArray == NULL)
+        {
+            DRVPRINTERROR("Error: pPmcConfigArray ptr is NULL");
+            retVal = -1;
+        }
+    }
+
+    if (!retVal)
+    {
+        pmcConfigCnt = pPmcConfigGroup->m_pmcConfigCnt;
+
+        pSmnConfig = &pClientCtx->m_pSmnConfig[smnTypeIdx];
+        if (pSmnConfig == NULL)
+        {
+            retVal = -1;
+            DRVPRINTERROR("Error: NULL ptr pSmnConfig");
+        }
+    }
+
+    if (!retVal)
+    {
+        maxNbioConfigs = sizeof(pSmnConfig->m_nbioFieldsConfig) / sizeof(pSmnConfig->m_nbioFieldsConfig[0]);
+        eventsPerPmc = pSmnConfig->m_nbioFieldsConfig[0].m_eventsPerPmcCnt;
+        nbioCnt = pSmnConfig->m_nbioFieldsConfig[0].m_nbioCnt;
+    }
+
+    if (eventsPerPmc == 0)
+    {
+        DRVPRINTERROR("Error: eventsPerPmcCnt is 0, would cause division by zero");
+        retVal = -1;
+    }
+
+    if (!retVal)
+    {
+        for (msrIdx = 0; (msrIdx < maxPmcCnt) && (pmcConfigCnt > 0); msrIdx++)
+        {
+            nbioIdx = (int)((msrIdx % maxPmcCnt) / eventsPerPmc);
+            pNbioConfig = &pSmnConfig->m_nbioFieldsConfig[nbioIdx];
+
+            pmcConfigCnt--;
+
+            if (pNbioConfig == NULL)
+            {
+                DRVPRINTERROR("Error: NULL ptr pNbioConfig");
+                retVal = -1;
+                break;
+            }
+
+            if (nbioIdx >= maxNbioConfigs)
+            {
+                DRVPRINTERROR("Error: Invalid NBIO index %d for pmcIdx %d", nbioIdx, msrIdx);
+                retVal = -1;
+                continue;
+            }
+
+
+            if (!pPmcConfigArray[msrIdx].m_controlValue)
+            {
+                continue;
+            }
+            
+            // Additional bounds check for msrIdx
+            if (msrIdx >= maxPmcCnt)
+            {
+                DRVPRINTERROR("Error: msrIdx %d exceeds maxPmcCnt %d", msrIdx, maxPmcCnt);
+                retVal = -1;
+                break;
+            }
+
+            for (unitIdx = 0; unitIdx < pNbioConfig->m_nbioCnt; unitIdx++)
+            {
+                pmcIdx = msrIdx % eventsPerPmc;
+
+                perfCntBase = pNbioConfig->m_nbioPerfCntBase + (unitIdx * pNbioConfig->m_nbioPerfCntStride);
+                ctrRegLoBase = pNbioConfig->m_nbioCtrRegLo + (pmcIdx * pNbioConfig->m_nbioCtrRegStride) + (unitIdx * pNbioConfig->m_nbioPerfCntStride);
+                ctrRegHiBase = pNbioConfig->m_nbioCtrRegHi + (pmcIdx * pNbioConfig->m_nbioCtrRegStride) + (unitIdx * pNbioConfig->m_nbioPerfCntStride);
+
+                if (msrIdx % eventsPerPmc == 0)
+                {
+                    smnAccess.m_isReadAccess = true;
+                    smnAccess.m_socket = socketId;  // Assuming socket 0
+                    smnAccess.m_address = perfCntBase; // NBIO_PERF_CNT_CTRL_OFFSET
+                    smnAccess.m_isBus = false;
+                    smnAccess.m_isMultiDomain = false;
+                    smnAccess.m_domainId = 0;
+
+                    if (!AccessSMN(pTargetSystemInfo, &smnAccess))
+                    {
+                        DRVPRINTERROR("Error: Failed to read NBIO PMC at 0x%x", smnAccess.m_address);
+                        retVal = -1;
+                        continue;
+                    }
+
+                    val = smnAccess.m_data;
+                    val &= 0xFFFFFFF8;
+                    val |= 0x3;  // From PPR (IOHC::NB_PERF_CNT_CTRL): shadow_wr & enable
+                    smnAccess.m_data = val;  // Reset value
+                    smnAccess.m_isReadAccess = false;
+
+                    if (!AccessSMN(pTargetSystemInfo, &smnAccess))
+                    {
+                        DRVPRINTERROR("Error: Failed to configure NBIO PMC for read at 0x%x", smnAccess.m_address);
+                        retVal = -1;
+                        continue;
+                    }
+                }
+                ctrIdx = maxPmcCnt * unitIdx + msrIdx;
+                if (ctrIdx >= (pPmcConfigGroup->m_pmcConfigCnt * pClientCtx->m_nbioCount[smnTypeIdx]))
+                {
+                    DRVPRINTERROR("Error: Counter index %d exceeds array bounds %d", ctrIdx, pPmcConfigGroup->m_pmcConfigCnt);
+                    retVal = -1;
+                    continue;
+                }
+                
+                if (pPmcConfigArray[msrIdx].m_controlValue == NBIO_DUMMY_EVENT)
+                {
+                    pPmcConfigGroup->counters.nbio.m_pNbioCountArray[ctrIdx] = 0;
+                }
+                else
+                {
+                    smnAccess.m_isReadAccess = true;
+                    smnAccess.m_address = ctrRegLoBase; // NBIO_PERF_CNT_CTRL_OFFSET
+                    smnAccess.m_data = 0;
+                    if (!AccessSMN(pTargetSystemInfo, &smnAccess))
+                    {
+                        DRVPRINTERROR("Error: Failed to read NBIO LO PMC at 0x%x", smnAccess.m_address);
+                        retVal = -1;
+                        continue;
+                    }
+                    val = smnAccess.m_data;
+
+                    smnAccess.m_address = ctrRegHiBase; // NBIO_PERF_CNT_CTRL_OFFSET
+                    smnAccess.m_data = 0;
+                    if (!AccessSMN(pTargetSystemInfo, &smnAccess))
+                    {
+                        DRVPRINTERROR("Error: Failed to read NBIO HI PMC at 0x%x", smnAccess.m_address);
+                        retVal = -1;
+                        continue;
+                    }
+
+                    valHi = smnAccess.m_data & 0xFFFFFF;
+                    pPmcConfigGroup->counters.nbio.m_pNbioCountArray[ctrIdx] = ((uint64_t)valHi << 32) | val;
+                }
+                DRVPRINT("NBIOTYPE[%d]: controlvalue=0x%llx, counterValue=0x%llx, ctrIdx(%d), eventsPerPmc(%d) socketId(%d) nbioId(%d)",
+                        nbioIdx, pPmcConfigArray[msrIdx].m_controlValue, pPmcConfigGroup->counters.nbio.m_pNbioCountArray[ctrIdx], ctrIdx, eventsPerPmc, socketId, unitIdx);
+            }
+        }
+    }
+    return retVal;
+}
