+        DRVPRINT("ioremap failed \n");
+        return STATUS_INVALID_PARAMETER;
+    }
+
+    DRVPRINT("PCI virtual address %p \n ", virtualAddress);
+
+    iowrite32(data, virtualAddress);
+    iounmap(virtualAddress);
+    return STATUS_SUCCESS;
+}
