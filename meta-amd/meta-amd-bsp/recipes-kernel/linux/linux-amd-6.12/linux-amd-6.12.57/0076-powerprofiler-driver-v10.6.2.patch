+        return;
+    }
+
+    maxNbioConfigs = sizeof(pSmnConfig->m_nbioFieldsConfig) / sizeof(pSmnConfig->m_nbioFieldsConfig[0]);
+
+    for (nbioIdx = 0; nbioIdx < maxNbioConfigs; nbioIdx++)
+    {
+        SmnNbioFieldsConfig* pNbioConfig = &pSmnConfig->m_nbioFieldsConfig[nbioIdx];
+        if (pNbioConfig == NULL)
+        {
+            DRVPRINTERROR("Error: pNbioConfig ptr is NULL");
+            continue;
+        }
+
+        for (unitIdx = 0; unitIdx < pNbioConfig->m_nbioCnt && pmcConfigCnt > 0; unitIdx++)
+        {
+            perfCntBase = pNbioConfig->m_nbioPerfCntBase + (unitIdx * pNbioConfig->m_nbioPerfCntStride);
+
+            // Reset this NBIO unit's performance counters
+            smnAccess.m_isReadAccess = true;
+            smnAccess.m_socket = socketId;  // Assuming socket 0
+            smnAccess.m_address = perfCntBase; // NBIO_PERF_CNT_CTRL_OFFSET
+            smnAccess.m_isBus = false;
+            smnAccess.m_isMultiDomain = false;
+            smnAccess.m_domainId = 0;
+
+            if (!AccessSMN(pTargetSystemInfo, &smnAccess))
+            {
+                DRVPRINTERROR("Error: Failed to read NBIO PMC at 0x%x", smnAccess.m_address);
+                continue;
+            }
+
+            val = smnAccess.m_data;
+            val &= 0xFFFFFFF8;
+            val |= 0x5;  // From PPR (IOHC::NB_PERF_CNT_CTRL): reset & enable
+            smnAccess.m_data = val;  // Reset value
+            smnAccess.m_isReadAccess = false;
+
+            if (!AccessSMN(pTargetSystemInfo, &smnAccess))
+            {
+                DRVPRINTERROR("Error: Failed to reset NBIO PMC at 0x%x", smnAccess.m_address);
+                continue;
+            }
+        }
+    }
+}
