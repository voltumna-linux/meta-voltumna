 void InitStatus(void)
 {
+    // Iterate through the MSR list and check for MSR availability based on CPUID bits
+    int cpuInfo[4] = { 0 };
+    uint32 cpuIdFn = 0;
+    const int eax = 0, ebx = 1, ecx = 2, edx = 3;
+    uint32_t largestExtCpuIdFunction = 0;
+    int idx = 0;
+    size_t nbrEntries = 0;
+    PTARGET_SYSTEM_INFO pTargetInfo = NULL;
+    WhitelistedMsrInfo* pMsrList = NULL;
+    uint32_t stride = 0;
+    uint32_t endAddr = 0;
+
+    if (g_isInit)
+    {
+        return;
+    }
+    else
+    {
+        g_isInit = true;
+    }
+
     SetMsrStatus();
+
+    GetTargetSystemInfo(&pTargetInfo, false);
+
+    if (pTargetInfo == NULL)
+    {
+        return;
+    }
+
+    // Check MSR availability from CPUID bits
+    pMsrList = (pTargetInfo->m_zen.m_isZen4AndAbove) ? g_msrListZen4 : g_msrListPreZen4;
+    nbrEntries = (pTargetInfo->m_zen.m_isZen4AndAbove) ? g_msrListZen4Size : g_msrListPreZen4Size;
+    nbrEntries = nbrEntries / sizeof(WhitelistedMsrInfo);
+
+    memset(cpuInfo, 0, sizeof(cpuInfo));
+
+    cpuIdFn = 0x80000000;
+    ReadCPUID(cpuInfo, cpuIdFn);
+
+    largestExtCpuIdFunction = (uint32_t)cpuInfo[eax];
+
+    for (idx = 0; idx < nbrEntries; idx++)
+    {
+        memset(cpuInfo, 0, sizeof(cpuInfo));
+
+        switch (pMsrList[idx].m_msrType)
+        {
+            case MSR_CORE_PMC:
+
+                pMsrList[idx].m_isAvailable = pTargetInfo->m_zen.m_perfMonInfo->m_numOfCorePmc ? true : false;
+
+                stride = 2;
+                endAddr = (pMsrList[idx].m_startMsrAddr + (pTargetInfo->m_zen.m_perfMonInfo->m_numOfCorePmc * stride)) - 1;
+
+                //DRVPRINTERROR("available(%d) START(x%x) m_endMsrAddr(x%x) endAddr(x%x)", pTargetInfo->m_zen.m_perfMonInfo->m_numOfCorePmc, pMsrList[idx].m_startMsrAddr, pMsrList[idx].m_endMsrAddr, endAddr);
+
+                if (pMsrList[idx].m_endMsrAddr != endAddr)
+                {
+                    pMsrList[idx].m_endMsrAddr = endAddr;
+                }
+
+                break;
+
+            case MSR_L3_PMC:
+                pMsrList[idx].m_isAvailable = pTargetInfo->m_zen.m_perfMonInfo->m_numOfL3Pmc ? true : false;
+                break;
+
+            case MSR_DF_PMC:
+                stride = 2;
+                pMsrList[idx].m_isAvailable = pTargetInfo->m_zen.m_perfMonInfo->m_numOfDfPmc ? true : false;
+                endAddr = (pMsrList[idx].m_startMsrAddr + (pTargetInfo->m_zen.m_perfMonInfo->m_numOfDfPmc * stride)) - 1;
+
+                if (pMsrList[idx].m_endMsrAddr != endAddr)
+                {
+                    pMsrList[idx].m_endMsrAddr = endAddr;
+                }
+                break;
+
+            case MSR_TSC_CLOCK:
+                cpuIdFn = 0x00000001;
+                ReadCPUID(cpuInfo, cpuIdFn);
+                pMsrList[idx].m_isAvailable = ((cpuInfo[edx] >> 4) & 0x1) ? true : false;
+                break;
+
+            case MSR_MPERF_READ_ONLY:
+            case MSR_APERF_READ_ONLY:
+                cpuIdFn = 0x80000007;
+                if (cpuIdFn <= largestExtCpuIdFunction)
+                {
+                    ReadCPUID(cpuInfo, cpuIdFn);
+                    pMsrList[idx].m_isAvailable = ((cpuInfo[edx] >> 10) & 0x1) ? true : false;
+                }
+                break;
+
+            case MSR_APERF:
+            case MSR_MPERF:
+                cpuIdFn = 0x00000006;
+                ReadCPUID(cpuInfo, cpuIdFn);
+                pMsrList[idx].m_isAvailable = (cpuInfo[ecx] & 0x1) ? true : false;
+                break;
+
+            case MSR_PSTATE_STATUS:
+                cpuIdFn = 0x80000007;
+                if (cpuIdFn <= largestExtCpuIdFunction)
+                {
+                    ReadCPUID(cpuInfo, cpuIdFn);
+                    pMsrList[idx].m_isAvailable = ((cpuInfo[edx] >> 7) & 0x1) ? true : false;
+                }
+                break;
+
+            case MSR_RAPL_PWR_UNIT:
+                cpuIdFn = 0x80000007;
+                if (cpuIdFn <= largestExtCpuIdFunction)
+                {
+                    ReadCPUID(cpuInfo, cpuIdFn);
+                    pMsrList[idx].m_isAvailable = ((cpuInfo[edx] >> 14) & 0x1) ? true : false;
+                }
+                break;
+
+            case MSR_UMC_PMC:
+                cpuIdFn = 0x80000022;
+                if (cpuIdFn <= largestExtCpuIdFunction)
+                {
+                    ReadCPUID(cpuInfo, cpuIdFn);
+                    pMsrList[idx].m_isAvailable = (((cpuInfo[ebx] >> 16) & 0xFF) > 0) ? true : false;
+
+                    // As per PPR, UMC MSRs for inactive UMC will ignore write and return 0 for reads.
+                    // Start and endAddr range for UMCs can vary across IODs based on active UMC (DIMMs)
+                }
+                break;
+
+            // These MSRs do not have CPUID bits to check availability
+            case MSR_HW_CONFIG:
+            case MSR_IRPERF_READ_ONLY:
+            // There is a cpuid for pstate curLim/Ctl/Stat but not for Pstate Def
+            case MSR_PSTATE_DEF:
+            case MSR_CORE_ENERGY_STAT:
+            // MSR C001_029B is not available on some PPRs ?
+            case MSR_PKG_ENERGY_STAT:
+            // Older PPRs
+            case MSR_LEGACY_CORE_PMC:
+            case MSR_CSTATE_CONFIG:
+            case MSR_CPUID_EXTENDED_FEATURES:
+            case MSR_LS_CONFIG:
+            case MSR_DE_CONFIG:
+                pMsrList[idx].m_isAvailable = true;
+                break;
+
+            default:
+                pMsrList[idx].m_isAvailable = true;
+                break;
+        }
+    }
 }
 
