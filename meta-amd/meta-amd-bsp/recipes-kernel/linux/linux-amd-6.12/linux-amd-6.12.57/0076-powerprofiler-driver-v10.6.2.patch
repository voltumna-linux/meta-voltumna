+bool GetMcfgTable(PCIEDomainList* pDomainList)
+{
+    struct acpi_table_header *pMcfgHeader;
+    struct acpi_table_mcfg *pMcfgEntry;
+    struct acpi_mcfg_allocation *pSegment;
+    uint32 domainCount = 0;
+    uint32 cnt = 0;
+    bool ret = false;
+
+    if (NULL == pDomainList)
+    {
+        DRVPRINTERROR("Error: pDomainList == NULL\n");
+        return ret;
+    }
+
+    if (acpi_get_table(ACPI_SIG_MCFG, 0, &pMcfgHeader) != AE_OK)
+    {
+        DRVPRINTERROR("Error: MCFG table not found\n");
+        return ret;
+    }
+
+    pMcfgEntry = (struct acpi_table_mcfg *)pMcfgHeader;
+
+    if (pMcfgHeader == NULL)
+    {
+        DRVPRINTERROR("Error: MCFG table pointer is NULL\n");
+        return ret;
+    }
+
+    pSegment = (struct acpi_mcfg_allocation *)(pMcfgEntry + 1);
+
+    if (pSegment == NULL)
+    {
+        DRVPRINTERROR("Error: MCFG entry allocation failed\n");
+        return ret;
+    }
+
+    domainCount = (pMcfgHeader->length - sizeof(struct acpi_table_mcfg)) / sizeof(struct acpi_mcfg_allocation);
+
+    if (domainCount > MAX_DOMAIN_COUNT)
+    {
+        DRVPRINTERROR("Error: Domain count exceeded (%d)\n", domainCount);
+        return ret;
+    }
+
+    pDomainList->m_domainCnt = domainCount;
+
+    for (cnt = 0; cnt < domainCount; cnt++)
+    {
+        pDomainList->m_domain[cnt].m_baseAddress = pSegment[cnt].address;
+        pDomainList->m_domain[cnt].m_segmentGroupId = pSegment[cnt].pci_segment;
+        pDomainList->m_domain[cnt].m_startBusId = pSegment[cnt].start_bus_number;
+        pDomainList->m_domain[cnt].m_endBusId = pSegment[cnt].end_bus_number;
+    }
+
+    acpi_put_table(pMcfgHeader);
+    return true;
+}
