From a4f79735097ba74e5348b7205f608a3424b79798 Mon Sep 17 00:00:00 2001
From: Gabriele <gabriele.brajnik@elettra.eu>
Date: Thu, 10 Nov 2022 15:17:47 +0100
Subject: [PATCH 03/10] changed adt address, enabled driver in defconfig

---
 arch/arm/boot/dts/socfpga_arria10_daq.dtsi | 4 ++--
 arch/arm/configs/socfpga_defconfig         | 2 ++
 2 files changed, 4 insertions(+), 2 deletions(-)

diff --git a/arch/arm/boot/dts/socfpga_arria10_daq.dtsi b/arch/arm/boot/dts/socfpga_arria10_daq.dtsi
index 7022099cccc4..9da56549366a 100644
--- a/arch/arm/boot/dts/socfpga_arria10_daq.dtsi
+++ b/arch/arm/boot/dts/socfpga_arria10_daq.dtsi
@@ -115,7 +115,7 @@ &i2c1 {
 	eeprom@57 {
 		compatible = "atmel,24c64";
 		reg = <0x57>;
-		pagesize = <64>;
+		pagesize = <32>;
 	};
 
 	rtc@51 {
@@ -125,7 +125,7 @@ rtc@51 {
 
 	fans@5c {
 		compatible = "adt7470";
-		reg = <0x58>;
+		reg = <0x2C>;
 	};
 };
 
diff --git a/arch/arm/configs/socfpga_defconfig b/arch/arm/configs/socfpga_defconfig
index b475ba84b896..855891791d3a 100644
--- a/arch/arm/configs/socfpga_defconfig
+++ b/arch/arm/configs/socfpga_defconfig
@@ -107,6 +107,7 @@ CONFIG_GPIO_ALTERA_A10SR=y
 CONFIG_SENSORS_ALTERA_A10SR=y
 CONFIG_SENSORS_MAX1619=y
 CONFIG_PMBUS=y
+CONFIG_SENSORS_ADT7470=y
 CONFIG_SENSORS_LTC2978=y
 CONFIG_SENSORS_LTC2978_REGULATOR=y
 CONFIG_WATCHDOG=y
@@ -135,6 +136,7 @@ CONFIG_LEDS_TRIGGER_TIMER=y
 CONFIG_LEDS_TRIGGER_CPU=y
 CONFIG_RTC_CLASS=y
 CONFIG_RTC_DRV_DS1307=y
+CONFIG_RTC_DRV_PCF85363=y
 CONFIG_DMADEVICES=y
 CONFIG_PL330_DMA=y
 CONFIG_DMATEST=m
-- 
2.34.1

