From 3c5d6d10660f9afded5ce23bbe2b8d55963f543d Mon Sep 17 00:00:00 2001
From: Gabriele <gabriele.brajnik@elettra.eu>
Date: Wed, 14 Dec 2022 11:41:01 +0100
Subject: [PATCH 09/10] enabled regulators always on and present at boot

---
 arch/arm/boot/dts/socfpga_arria10_daq.dtsi | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/arch/arm/boot/dts/socfpga_arria10_daq.dtsi b/arch/arm/boot/dts/socfpga_arria10_daq.dtsi
index ee4e543b3546..d19444144bd2 100644
--- a/arch/arm/boot/dts/socfpga_arria10_daq.dtsi
+++ b/arch/arm/boot/dts/socfpga_arria10_daq.dtsi
@@ -98,6 +98,7 @@ regulator_3_3v: 3-3-v-regulator {
 		regulator-min-microvolt = <3300000>;
 		regulator-max-microvolt = <3300000>;
 		regulator-always-on;
+		regulator-boot-on;
 	};
 
 	regulator_1_8v: 1-8-v-regulator {
@@ -106,6 +107,7 @@ regulator_1_8v: 1-8-v-regulator {
 		regulator-min-microvolt = <1800000>;
 		regulator-max-microvolt = <1800000>;
 		regulator-always-on;
+		regulator-boot-on;
 	};
 
 	/* 48MHz reference crystal for Si5340 */
-- 
2.34.1

