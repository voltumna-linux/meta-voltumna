From d7fbf0cfa77be4dc9641c7260ea1abc455827bba Mon Sep 17 00:00:00 2001
From: Gabriele <gabriele.brajnik@elettra.eu>
Date: Wed, 9 Nov 2022 18:14:42 +0100
Subject: [PATCH 03/10] updated device tree for daq board

---
 arch/arm/dts/socfpga_arria10_daq.dtsi | 123 +++++++++-----------------
 1 file changed, 44 insertions(+), 79 deletions(-)

diff --git a/arch/arm/dts/socfpga_arria10_daq.dtsi b/arch/arm/dts/socfpga_arria10_daq.dtsi
index 0efbeccc5c..7022099ccc 100644
--- a/arch/arm/dts/socfpga_arria10_daq.dtsi
+++ b/arch/arm/dts/socfpga_arria10_daq.dtsi
@@ -5,8 +5,8 @@
 #include "socfpga_arria10.dtsi"
 
 / {
-	model = "Altera SOCFPGA Arria 10";
-	compatible = "altr,socfpga-arria10", "altr,socfpga";
+	model = "ElettraST DAQ";
+	compatible = "elettrast,socfpga-arria10-daq","altr,socfpga-arria10", "altr,socfpga";
 
 	aliases {
 		ethernet0 = &gmac0;
@@ -24,37 +24,38 @@
 		reg = <0x0 0x40000000>; /* 1GB */
 	};
 
-	a10leds {
+	leds {
 		compatible = "gpio-leds";
 
-		a10sr_led0 {
-			label = "a10sr-led0";
-			gpios = <&a10sr_gpio 0 1>;
+		hps_led0 {
+			label = "hps_led0";
+			gpios = <&portb 15 0>;	/* HPS_GPIO1_15 */
+			linux,default-trigger = "heartbeat";
 		};
 
-		a10sr_led1 {
-			label = "a10sr-led1";
-			gpios = <&a10sr_gpio 1 1>;
+		hps_led1 {
+			label = "hps_led1";
+			gpios = <&portb 14 0>;	/* HPS_GPIO1_14 */
+			linux,default-trigger = "heartbeat";
 		};
+	};
 
-		a10sr_led2 {
-			label = "a10sr-led2";
-			gpios = <&a10sr_gpio 2 1>;
-		};
+	gpio-keys {
+		compatible = "gpio-keys";
 
-		a10sr_led3 {
-			label = "a10sr-led3";
-			gpios = <&a10sr_gpio 3 1>;
+		hps_sw0 {
+			label = "hps_sw0";
+			gpios = <&portb 17 0>;	/* HPS_GPIO1_17 */
+			linux,input-type = <5>;	/* EV_SW */
 		};
-	};
 
-	ref_033v: 033-v-ref {
-		compatible = "regulator-fixed";
-		regulator-name = "0.33V";
-		regulator-min-microvolt = <330000>;
-		regulator-max-microvolt = <330000>;
+		hps_sw1 {
+			label = "hps_sw1";
+			gpios = <&portb 16 0>;	/* HPS_GPIO1_16 */
+			linux,input-type = <5>;	/* EV_SW */
+		};
 	};
-
+	
 	soc {
 		clkmgr@ffd04000 {
 			clocks {
@@ -78,18 +79,22 @@
 	 * range from a negative skew to a positive skew.
 	 * See the micrel-ksz90x1.txt Documentation file for details.
 	 */
-	txd0-skew-ps = <0>; /* -420ps */
-	txd1-skew-ps = <0>; /* -420ps */
-	txd2-skew-ps = <0>; /* -420ps */
-	txd3-skew-ps = <0>; /* -420ps */
+	txd0-skew-ps = <420>; /* 0ps */
+	txd1-skew-ps = <420>; /* 0ps */
+	txd2-skew-ps = <420>; /* 0ps */
+	txd3-skew-ps = <420>; /* 0ps */
+
 	rxd0-skew-ps = <420>; /* 0ps */
 	rxd1-skew-ps = <420>; /* 0ps */
 	rxd2-skew-ps = <420>; /* 0ps */
 	rxd3-skew-ps = <420>; /* 0ps */
-	txen-skew-ps = <0>; /* -420ps */
-	txc-skew-ps = <1860>; /* 960ps */
+
+	txen-skew-ps = <420>; /* 0ps */
 	rxdv-skew-ps = <420>; /* 0ps */
-	rxc-skew-ps = <1680>; /* 780ps */
+
+	rxc-skew-ps = <900>; /* 0ps */
+	txc-skew-ps = <900>; /* 0ps */
+
 	max-frame-size = <3800>;
 	status = "okay";
 };
@@ -100,67 +105,27 @@
 
 &spi1 {
 	status = "okay";
-
-	resource-manager@0 {
-		compatible = "altr,a10sr";
-		reg = <0>;
-		spi-max-frequency = <100000>;
-		/* low-level active IRQ at GPIO1_5 */
-		interrupt-parent = <&portb>;
-		interrupts = <5 IRQ_TYPE_LEVEL_LOW>;
-		interrupt-controller;
-		#interrupt-cells = <2>;
-
-		a10sr_gpio: gpio-controller {
-			compatible = "altr,a10sr-gpio";
-			gpio-controller;
-			#gpio-cells = <2>;
-		};
-
-		a10sr_rst: reset-controller {
-			compatible = "altr,a10sr-reset";
-			#reset-cells = <1>;
-		};
-	};
 };
 
 &i2c1 {
 	status = "okay";
 
-	/*
-	 * adjust the falling times to decrease the i2c frequency to 50Khz
-	 * because the LCD module does not work at the standard 100Khz
-	 */
 	clock-frequency = <100000>;
-	i2c-sda-falling-time-ns = <6000>;
-	i2c-scl-falling-time-ns = <6000>;
-
-	adc@14 {
-		compatible = "lltc,ltc2497";
-		reg = <0x14>;
-		vref-supply = <&ref_033v>;
-	};
 
-	adc@16 {
-		compatible = "lltc,ltc2497";
-		reg = <0x16>;
-		vref-supply = <&ref_033v>;
+	eeprom@57 {
+		compatible = "atmel,24c64";
+		reg = <0x57>;
+		pagesize = <64>;
 	};
 
-	eeprom@51 {
-		compatible = "atmel,24c32";
+	rtc@51 {
+		compatible = "nxp,pcf85363";
 		reg = <0x51>;
-		pagesize = <32>;
-	};
-
-	rtc@68 {
-		compatible = "dallas,ds1339";
-		reg = <0x68>;
 	};
 
-	ltc@5c {
-		compatible = "ltc2977";
-		reg = <0x5c>;
+	fans@5c {
+		compatible = "adt7470";
+		reg = <0x58>;
 	};
 };
 
-- 
